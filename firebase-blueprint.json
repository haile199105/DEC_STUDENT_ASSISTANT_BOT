{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "A daily note for students.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the note" },
        "content": { "type": "string", "description": "Content of the note" },
        "date": { "type": "string", "format": "date", "description": "Date for the note" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "content", "date"]
    },
    "Question": {
      "title": "Question",
      "description": "A study question for students.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The question text" },
        "answer": { "type": "string", "description": "The correct answer" },
        "subject": { "type": "string", "description": "Subject of the question" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["text", "answer"]
    },
    "Book": {
      "title": "Book",
      "description": "A student book source.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the book" },
        "content": { "type": "string", "description": "Full text content of the book for AI context" },
        "subject": { "type": "string", "description": "Subject of the book" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "notes": { "schema": "Note", "description": "Collection of daily notes" },
    "questions": { "schema": "Question", "description": "Collection of study questions" },
    "books": { "schema": "Book", "description": "Collection of student books" }
  }
}
